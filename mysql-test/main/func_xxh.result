CREATE TABLE t (c INT, d VARCHAR(3)) DEFAULT CHARSET=latin1;
INSERT INTO t VALUES (11223344, 'abc');
SELECT XXH32(c) = XXH32(11223344) AS xxh32_col_eq,
XXH32(d) = XXH32('abc') AS xxh32_str_col_eq
FROM t;
xxh32_col_eq	xxh32_str_col_eq
1	1
SELECT XXH3(c) = XXH3(11223344) AS xxh3_col_eq,
XXH3(d) = XXH3('abc') AS xxh3_str_col_eq
FROM t;
xxh3_col_eq	xxh3_str_col_eq
1	1
DROP TABLE t;
